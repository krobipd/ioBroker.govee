{
  "name": "iobroker.govee-smart",
  "version": "2.1.4",
  "description": "Control Govee WiFi devices via LAN, MQTT and Cloud.",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.govee-smart",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "govee",
    "smart home",
    "led",
    "light"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.govee-smart"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.1",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^10.0.0",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin",
    "build",
    "devices.json",
    "devices.schema.json",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "mocha --config test/mocharc.custom.json \"src/**/*.test.ts\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "coverage": "nyc npm run test:ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "translate": "translate-adapter",
    "release": "release-script",
    "validate-devices": "ts-node tools/validate-devices.ts",
    "gen-wiki": "ts-node tools/gen-wiki-devices.ts"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.govee-smart/issues"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  }
}
